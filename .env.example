# ================================================
# 爬虫逆向框架 - 环境变量配置示例
# 复制此文件为 .env 并修改相应值
# ================================================

# -------- 环境模式 --------
# 可选值: development, production
ENV=development

# -------- Redis 配置 --------
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAXMEMORY=256mb

# -------- MongoDB 配置 --------
MONGODB_PORT=27017
MONGODB_DB=crawler
MONGODB_USER=
MONGODB_PASSWORD=

# -------- 爬虫核心配置 --------
CONCURRENT=5
DOWNLOAD_DELAY=1.0
RATE_LIMIT=10.0
RETRY_TIMES=3
TIMEOUT=30
LOG_LEVEL=INFO

# -------- 代理配置 --------
PROXY_ENABLED=false
# PROXY_POOL=http://proxy1:8080,http://proxy2:8080

# -------- 存储配置 --------
# 可选值: file, mongodb, mysql
STORAGE_TYPE=file
STORAGE_URL=

# -------- 端口配置 --------
# Crawler 服务端口
APP_PORT=8000
